@import "https://fonts.googleapis.com/css?family=Roboto:400,700";html{overflow-y:scroll}body{font:100% roboto;margin:0;font-size:13px;color:#727779}h1{color:#239123;margin:0;font-size:3vw;text-transform:uppercase;line-height:120%;padding:0% 0% 2% 0}h2{color:#239123;margin:0;font-size:2vw;text-transform:uppercase;line-height:120%;padding:0% 0% 2% 0}a{color:#2daaf4;text-align:center;text-decoration:none;border:0;outline:0}.notification{position:fixed;top:50px;right:0;border-radius:4px;padding:25px;margin-right:1%;max-width:17%;color:#fefefe;width:10%;z-index:999}.error{background-color:#d24e6f}.message{background-color:#4ed2b1}navbar{width:100%;height:50px;position:fixed;top:0%;z-index:5;background-color:transparent;text-transform:uppercase;-webkit-transition:all .5s;-moz-transition:all .5s;-o-transition:all .5s;transition:all .5s;background-color:#fff;box-shadow:0 1px 2px rgba(0,0,0,.2)}navbar *{-webkit-transition:all 1s;-moz-transition:all 1s;-o-transition:all 1s;transition:all 1s}navbar ul{list-style-type:none;text-align:center;padding-top:2px;padding-left:0}navbar ul li{display:inline;padding:1% 2%;text-decoration:none}navbar ul li a{font-size:1em;font-weight:400;color:#656555;text-decoration:none}navbar ul li a:hover{cursor:pointer}#main{position:relative}#background{width:100%;height:100%;position:fixed;overflow:hidden;text-align:center;-webkit-background-size:cover;-moz-background-size:cover;-o-background-size:cover;background-size:cover;background-image:url(/images/20230211_143406_hu9b9b0c67f96e331e1bd8ab0305e32e06_4103411_1900x0_resize_q95_h2_box.webp);top:0;opacity:.15}section{border-top:1px solid #ccc;height:100%;text-align:center;padding:7% 0}#page-welcome-text-div{background-color:#fff;width:3rem;text-align:center;margin:auto;width:30%;padding:10px;background:rgba(235,235,235,.75);border-radius:1em;margin-top:7%}#page-welcome-text{opacity:1!important}#page-welcome{padding:10% 0% 18%;-webkit-background-size:cover;-moz-background-size:cover;-o-background-size:cover;background-size:cover;background-image:url(/images/kampioenschap_hud103cbe40ee2bda7a6dafdf1eb786191_641269_1900x0_resize_q50_h2_box.webp)}#page-teams{background-color:#fefefe}#page-leaders table{margin:0 auto;min-width:40%}#page-leaders table tr td{padding:2%}#page-training{background-color:#fefefe}#page-training table{margin:0 auto;min-width:25%}#page-training table tr td{width:100px;padding:2%}#page-location{background-color:#fefefe}#page-location #gmap{margin-top:3%}#page-contact{background-color:#fefefe}#page-contact #contact_form form{margin:auto;width:30%}#page-contact #contact_form form label{font-size:1.2em;margin-bottom:500px}#page-contact #contact_form form input{padding:1%;width:50%;border:1px solid #aaa;display:block;margin:3% auto 5%}#page-contact #contact_form form textarea{padding:1%;width:60%;height:9vh;display:block;margin:5% auto;border:1px solid #aaa}#page-contact #contact_form form button{display:block;margin:auto;width:30%;border:#3c3c3c solid 4px;cursor:pointer;background-color:#3c3c3c;color:#fefefe;font-size:20px;padding-top:8px;padding-bottom:8px;-webkit-transition:all .5s;-moz-transition:all .5s;transition:all .5s;font-weight:700;border-radius:.4em}#page-contact #contact_form form button:hover{background-color:#fefefe;color:#3c3c3c;border:#fefefe solid 4px}#page-footer{padding:1% 0%;background-color:#fefefe}@media only screen and (max-width:800px){body{font-size:10px}p{padding:0% 5%}#page-leaders{background-color:#fefefe}.no-mobile{display:none}navbar{display:none}#page-contact{background-color:#fefefe}#page-contact #contact_form form{width:90%}}